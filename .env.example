# Copy this file to `.env` and fill in real values.
# The real `.env` is gitignored and must NEVER be committed.
#
#   cp .env.example .env
#
# ---------------------------------------------------------------------------
# Postgres
# ---------------------------------------------------------------------------
POSTGRES_USER=n8n
POSTGRES_PASSWORD=          # generate: openssl rand -hex 24
POSTGRES_DB=n8n

# ---------------------------------------------------------------------------
# n8n encryption key  —  THE MASTER KEY. Read the README before touching this.
# ---------------------------------------------------------------------------
# Decrypts every stored credential (email, Azure, Mistral, delivery creds).
# Treat it like a root password.
#   - Generate once:  openssl rand -hex 32
#   - Set it BEFORE the first run, or n8n auto-generates its own and a later
#     mismatch will refuse to start.
#   - Store the value in a password manager / secrets vault, NOT just here.
#   - Losing it = every credential becomes undecryptable on restore.
N8N_ENCRYPTION_KEY=

# ---------------------------------------------------------------------------
# Networking
# ---------------------------------------------------------------------------
# For local prototyping the defaults below are fine. Once a domain + reverse
# proxy / VPN is in place, set these to the real public values.
N8N_HOST=localhost
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/
GENERIC_TIMEZONE=America/Vancouver

# ---------------------------------------------------------------------------
# Optional: Python extractor sidecar (uncomment the service in compose first)
# ---------------------------------------------------------------------------
# AZURE_DI_KEY=
# MISTRAL_API_KEY=

